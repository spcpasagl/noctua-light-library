<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Manajemen Berita - Noctua Light</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: 'class',
      theme: { extend: { colors: { navy: { DEFAULT: '#0A1931', dark: '#050C1A', mid: '#15305B', light: '#1E3E6D' }, gold: { DEFAULT: '#E5A93C' }, cream: { DEFAULT: '#FAF8F5', secondary: '#F1EDE6', dark: '#070F21' } }, fontFamily: { sans: ['Inter', 'sans-serif'], heading: ['Plus Jakarta Sans', 'sans-serif'] } } }
    }
  </script>
  <script src="assets/js/database.js"></script>
  <script src="assets/js/app.js"></script>
  <script src="assets/js/auth.js"></script>
</head>
<body class="bg-cream dark:bg-cream-dark text-navy dark:text-white font-sans transition-colors duration-300">

<div class="container mx-auto p-4 max-w-5xl">
  <div class="bg-white dark:bg-navy-mid p-5 rounded-2xl shadow-sm border border-navy/5 flex justify-between items-center mb-8 gap-4">
    <div class="flex items-center gap-3">
      <h1 class="text-2xl font-heading font-bold tracking-tight">Manajemen Berita & Agenda</h1>
    </div>
    <div class="flex items-center gap-3">
      <button id="darkToggle" onclick="toggleDarkMode(); window.location.reload();" class="w-10 h-10 flex items-center justify-center rounded-xl bg-cream-secondary dark:bg-navy-dark hover:bg-navy/10 transition">
        <span class="font-bold">D/L</span>
      </button>
      <a href="admin-dashboard.html" class="bg-navy-light text-white text-xs font-bold uppercase tracking-wider px-4 py-2.5 rounded-xl hover:bg-navy transition shadow-sm">&larr; Dasbor</a>
    </div>
  </div>

  <div class="mb-6">
    <button id="btnTambah" class="bg-navy text-white dark:bg-gold dark:text-navy text-xs font-bold uppercase tracking-wider px-5 py-3 rounded-xl hover:opacity-90 shadow-md transition transform hover:-translate-y-0.5">
      + Buat Warta Baru
    </button>
  </div>

  <div class="bg-white dark:bg-navy-mid rounded-2xl shadow-sm border border-navy/5 overflow-hidden">
    <table class="w-full text-sm text-left border-collapse">
      <thead class="bg-cream dark:bg-navy text-xs uppercase tracking-wider text-navy/60 dark:text-white/60 font-bold border-b border-navy/10">
        <tr>
          <th class="px-4 py-4 w-24">ID</th>
          <th class="px-4 py-4 w-32">Tanggal</th>
          <th class="px-4 py-4">Judul Berita</th>
          <th class="px-4 py-4 text-center w-32">Aksi</th>
        </tr>
      </thead>
      <tbody id="tabelBerita" class="divide-y divide-navy/5 font-light text-xs">
      </tbody>
    </table>
  </div>
</div>

<div id="modalForm" class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50 p-4 backdrop-blur-sm transition-all duration-300">
  <div class="bg-white dark:bg-navy-mid rounded-2xl shadow-2xl w-full max-w-2xl border border-navy/10 flex flex-col overflow-hidden">
    <div class="bg-cream dark:bg-navy-dark border-b border-navy/10 px-6 py-4 flex justify-between items-center">
      <h2 id="modalTitle" class="text-xl font-heading font-bold text-navy dark:text-white">Tambah/Edit Berita</h2>
      <button onclick="closeModal()" class="text-navy/50 hover:text-navy text-2xl font-bold transition">&times;</button>
    </div>
    
    <div class="p-6">
      <form id="beritaForm" class="space-y-4 text-sm">
        <input type="hidden" id="editId">

        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-xs font-bold uppercase tracking-widest mb-1.5 ml-1">Tanggal *</label>
            <input type="date" id="tanggal" class="w-full bg-cream-secondary dark:bg-navy-dark px-4 py-2.5 rounded-xl focus:outline-none text-navy dark:text-white" required>
          </div>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest mb-1.5 ml-1">Judul Berita *</label>
          <input type="text" id="judul" class="w-full bg-cream-secondary dark:bg-navy-dark px-4 py-2.5 rounded-xl focus:outline-none text-navy dark:text-white" required>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest mb-1.5 ml-1">Isi Berita *</label>
          <textarea id="konten" rows="5" class="w-full bg-cream-secondary dark:bg-navy-dark px-4 py-2.5 rounded-xl focus:outline-none text-navy dark:text-white resize-none" required></textarea>
        </div>

        <div>
          <label class="block text-xs font-bold uppercase tracking-widest mb-1.5 ml-1">URL Gambar Header</label>
          <input type="url" id="gambar" class="w-full bg-cream-secondary dark:bg-navy-dark px-4 py-2.5 rounded-xl focus:outline-none text-navy dark:text-white" placeholder="https://...">
        </div>

        <div class="flex justify-end gap-3 pt-4 border-t border-navy/5 mt-4">
          <button type="button" onclick="closeModal()" class="bg-cream-secondary text-navy dark:bg-navy-dark dark:text-white px-6 py-3 rounded-xl text-xs font-bold uppercase tracking-wider hover:opacity-80 transition">Batal</button>
          <button type="submit" class="bg-navy text-white dark:bg-gold dark:text-navy px-6 py-3 rounded-xl text-xs font-bold uppercase tracking-wider hover:opacity-90 transition">Simpan</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script>
  if (!checkSession()) window.location.href = "login.html";

  function renderTabel() {
    const berita = getAllBerita().sort((a, b) => new Date(b.tanggal) - new Date(a.tanggal));
    const tbody = document.getElementById("tabelBerita");
    
    if (!berita.length) {
      tbody.innerHTML = '<tr><td colspan="4" class="text-center p-6">Belum ada warta tercatat.</td></tr>';
      return;
    }

    tbody.innerHTML = berita.map(item => `
      <tr class="hover:bg-cream-secondary/30 transition-colors">
        <td class="px-4 py-3 border-b border-navy/5 font-bold">${item.id}</td>
        <td class="px-4 py-3 border-b border-navy/5">${item.tanggal}</td>
        <td class="px-4 py-3 border-b border-navy/5 font-semibold truncate max-w-xs">${item.judul}</td>
        <td class="px-4 py-3 border-b border-navy/5 text-center flex justify-center gap-2">
          <button onclick='openEditModal(${JSON.stringify(item)})' class="bg-navy/10 text-navy p-2 rounded-xl text-xs font-bold hover:bg-navy/20">Edit</button>
          <button onclick="hapusBerita('${item.id}')" class="bg-red-600/10 text-red-600 p-2 rounded-xl text-xs font-bold hover:bg-red-600 hover:text-white transition">Hapus</button>
        </td>
      </tr>
    `).join('');
  }

  function hapusBerita(id) {
    if (confirm("Hapus berita ini?")) {
      const filtered = getAllBerita().filter(b => b.id !== id);
      saveAllBerita(filtered);
      renderTabel();
    }
  }

  function openEditModal(item = null) {
    const modal = document.getElementById("modalForm");
    modal.classList.remove("hidden"); modal.classList.add("flex");
    
    if (item) {
      document.getElementById("modalTitle").innerText = "Edit Berita";
      document.getElementById("editId").value = item.id;
      document.getElementById("tanggal").value = item.tanggal;
      document.getElementById("judul").value = item.judul;
      document.getElementById("konten").value = item.konten;
      document.getElementById("gambar").value = item.gambar || "";
    } else {
      document.getElementById("modalTitle").innerText = "Buat Warta Baru";
      document.getElementById("beritaForm").reset();
      document.getElementById("editId").value = "";
    }
  }

  function closeModal() {
    document.getElementById("modalForm").classList.add("hidden");
    document.getElementById("modalForm").classList.remove("flex");
  }

  document.getElementById("beritaForm").addEventListener("submit", (e) => {
    e.preventDefault();
    const idEdit = document.getElementById("editId").value;
    let berita = getAllBerita();
    
    const idBaru = idEdit ? idEdit : "BR" + String(berita.length ? Math.max(...berita.map(b => parseInt(b.id.replace('BR','')))) + 1 : 1).padStart(3, '0');

    const newData = {
      id: idBaru,
      tanggal: document.getElementById("tanggal").value,
      judul: document.getElementById("judul").value,
      konten: document.getElementById("konten").value,
      gambar: document.getElementById("gambar").value
    };

    if (idEdit) {
      const idx = berita.findIndex(b => b.id === idEdit);
      berita[idx] = newData;
    } else {
      berita.push(newData);
    }
    
    saveAllBerita(berita);
    closeModal();
    renderTabel();
  });

  document.getElementById("btnTambah").addEventListener("click", () => openEditModal(null));
  renderTabel();
</script>
</body>
</html>
